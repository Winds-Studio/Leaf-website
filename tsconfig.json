{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["esnext", "dom"],
        "paths": {
            "@/*": ["./*"]
        },
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "**/.vitepress/**/*.ts",
        "**/.vitepress/**/*.mts",
        "**/.vitepress/**/*.vue",
        "**/pages/**/*.ts",
        "**/.vitepress/theme/index.tsx",
        "**/*.d.ts"
    ],
    "exclude": ["node_modules"]
}
